    "/api/settings/smtp": {
      "get": {
        "tags": ["Settings"],
        "summary": "Get SMTP settings",
        "security": [{ "bearerAuth": [] }, { "sessionAuth": [] }],
        "responses": { "200": { "description": "SMTP config" } }
      },
      "put": {
        "tags": ["Settings"],
